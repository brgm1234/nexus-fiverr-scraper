{
  "title": "Fiverr Scraper Input",
  "description": "Configuration for Fiverr gig scraping",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "keywords": {
      "title": "Search Keywords",
      "type": "array",
      "description": "Keywords to search for gigs on Fiverr",
      "items": { "type": "string" },
      "editor": "stringList"
    },
    "maxGigs": {
      "title": "Maximum Gigs",
      "type": "integer",
      "description": "Maximum number of gigs to scrape",
      "default": 30,
      "minimum": 1,
      "maximum": 500
    }
  },
  "required": ["keywords"]
}